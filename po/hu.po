msgid "  /,s: search | Enter: play | Space: pause | n/p: next/prev | R: shuffle | t: jump"
msgstr "  /,s: keresés | Enter: lejátszás | Space: szünet | n/p: köv./előző | R: keverés | t: ugrás"

msgid "  Left/Right: seek | a: add | d: download | f: playlists | S: settings | q: quit"
msgstr "  Bal/Jobb: tekerés | a: hozzáadás | d: letöltés | f: listák | S: beállítások | q: kilépés"

